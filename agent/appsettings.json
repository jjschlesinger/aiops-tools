{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },
  "Agent": {
    // Executable that launches the MCP server.
    // In dev: "dotnet" with the arguments below runs the mcpserver project.
    // In production: set to the path of the published mcpserver binary.
    "McpServerCommand": "dotnet",
    "McpServerArguments": [ "run", "--project", "../mcpserver", "--no-build" ],

    // Claude model to use. See https://docs.anthropic.com/en/docs/about-claude/models
    "Model": "claude-opus-4-5-20250929",

    // Analyse errors from the last N hours.
    "TimeRangeHours": 24,

    // Maximum log entries retrieved per repository.
    "MaxResults": 200,

    // Minutes between runs. Set to 0 for one-shot mode (run once, then exit).
    "IntervalMinutes": 60,

    // Where to write per-run JSON result files (relative to the agent exe).
    "OutputDirectory": "results",

    // Claude's max_tokens per response turn.
    "MaxTokensPerTurn": 8192
  }
}
